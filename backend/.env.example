# ARGOS Backend Configuration
# ---------------------------

# Finnhub API Key (get it from https://finnhub.io)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Database URL (Postgres)
# Example: postgresql://user:password@localhost:5432/argos
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/argos

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Update Cron (default daily at midnight)
UPDATE_CRON=0 0 * * *

# System Timezone
TIMEZONE=America/Argentina/Buenos_Aires
